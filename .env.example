# KitchenKeep Configuration
# Copy this file to /opt/kitchenkeep/.env and edit as needed.
# Restart the kitchenkeep service after making changes:
#   systemctl restart kitchenkeep

# Ollama model to use for recipe extraction.
# Options: mistral (default, 7B), phi3:mini (3.8B, low-RAM), llama3 (8B, high-quality)
# After changing, run: ollama pull <new-model-name>
OLLAMA_MODEL=mistral

# Ollama API base URL. Do not change unless you know what you're doing.
OLLAMA_BASE_URL=http://localhost:11434

# Web app port. Open this port in your firewall/Proxmox if you change it.
APP_PORT=8000
APP_HOST=0.0.0.0

# Database location. Created automatically on first run.
DATABASE_URL=sqlite:////opt/kitchenkeep/data/recipes.db

# Set to true to enable FastAPI debug mode (never use in production)
DEBUG=false
